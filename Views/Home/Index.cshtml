@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap');

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    /* HERO */
    .hero {
        min-height: 92vh;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        padding: 3rem 1.5rem;
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        background-image: url('https://images.unsplash.com/photo-1486325212027-8081e485255e?w=1600&q=80');
        background-size: cover;
        background-position: center;
        filter: brightness(0.35);
        z-index: 0;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(10,10,30,0.85) 0%, rgba(15,31,61,0.75) 50%, rgba(10,48,96,0.65) 100%);
        z-index: 1;
    }

    .hero-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        max-width: 1100px;
        width: 100%;
        align-items: center;
        position: relative;
        z-index: 2;
    }

    .hero-text {
        color: white;
    }

    .hero-eyebrow {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: #5dade2;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .hero-eyebrow::before {
            content: '';
            display: inline-block;
            width: 30px;
            height: 2px;
            background: #5dade2;
        }

    .hero-title {
        font-family: 'Playfair Display', serif;
        font-size: 3.6rem;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 1.5rem;
        color: white;
    }

        .hero-title span {
            color: #5dade2;
            display: block;
        }

    .hero-desc {
        font-family: 'DM Sans', sans-serif;
        font-size: 1.05rem;
        color: rgba(255,255,255,0.75);
        line-height: 1.75;
        margin-bottom: 2.5rem;
        font-weight: 300;
    }

    .hero-buttons {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .btn-hero-primary {
        background: #2980b9;
        color: white;
        padding: 0.85rem 2rem;
        border-radius: 50px;
        text-decoration: none;
        font-family: 'DM Sans', sans-serif;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.3s;
        box-shadow: 0 8px 25px rgba(41,128,185,0.5);
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

        .btn-hero-primary:hover {
            background: #3498db;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 12px 30px rgba(41,128,185,0.6);
        }

    .btn-hero-secondary {
        background: transparent;
        color: white;
        padding: 0.85rem 2rem;
        border-radius: 50px;
        text-decoration: none;
        font-family: 'DM Sans', sans-serif;
        font-weight: 600;
        font-size: 0.95rem;
        border: 2px solid rgba(255,255,255,0.4);
        transition: all 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

        .btn-hero-secondary:hover {
            border-color: white;
            color: white;
            background: rgba(255,255,255,0.1);
        }

    /* PROPERTY CARDS IN HERO */
    .hero-visual {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .prop-card-img {
        border-radius: 16px;
        overflow: hidden;
        position: relative;
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        transition: transform 0.3s;
    }

        .prop-card-img:hover {
            transform: translateY(-4px);
        }

        .prop-card-img img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            display: block;
        }

        .prop-card-img.small img {
            height: 130px;
        }

    .prop-card-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(transparent, rgba(0,0,0,0.82));
        padding: 1.25rem 1rem 0.85rem;
        color: white;
    }

    .prop-card-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .prop-tag {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #5dade2;
        margin-bottom: 0.2rem;
    }

    .prop-name {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.9rem;
        font-weight: 600;
        color: white;
    }

    .prop-price-tag {
        font-family: 'Playfair Display', serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: white;
    }

    .prop-badge {
        display: inline-block;
        background: #27ae60;
        color: white;
        font-size: 0.65rem;
        font-weight: 700;
        padding: 0.18rem 0.55rem;
        border-radius: 20px;
        letter-spacing: 0.5px;
        margin-left: 0.4rem;
        vertical-align: middle;
    }

    /* STATS */
    .stats-bar {
        background: #0f1f3d;
        padding: 2rem 1.5rem;
    }

    .stats-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
        text-align: center;
    }

    .stat-item {
        padding: 1rem;
        border-right: 1px solid rgba(255,255,255,0.08);
    }

        .stat-item:last-child {
            border-right: none;
        }

    .stat-number {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        font-weight: 900;
        color: #5dade2;
        display: block;
    }

    .stat-label {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.82rem;
        color: rgba(255,255,255,0.55);
        font-weight: 500;
        letter-spacing: 0.5px;
        margin-top: 0.25rem;
    }

    /* FEATURES */
    .features-section {
        background: #f4f7fb;
        padding: 5rem 1.5rem;
    }

    .section-label {
        text-align: center;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: #2980b9;
        margin-bottom: 0.75rem;
    }

    .section-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.4rem;
        font-weight: 900;
        color: #0f1f3d;
        text-align: center;
        margin-bottom: 3.5rem;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.75rem;
        max-width: 1100px;
        margin: 0 auto;
    }

    .feature-card {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.06);
        transition: all 0.3s;
        border-top: 4px solid transparent;
    }

        .feature-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 35px rgba(0,0,0,0.12);
            border-top-color: #2980b9;
        }

    .feature-img {
        width: 100%;
        height: 160px;
        object-fit: cover;
        display: block;
    }

    .feature-body {
        padding: 1.5rem;
    }

    .feature-emoji {
        font-size: 1.8rem;
        margin-bottom: 0.75rem;
        display: block;
    }

    .feature-title {
        font-family: 'DM Sans', sans-serif;
        font-size: 1.05rem;
        font-weight: 700;
        color: #0f1f3d;
        margin-bottom: 0.5rem;
    }

    .feature-desc {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.88rem;
        color: #6c757d;
        line-height: 1.7;
    }

    /* ROLES */
    .roles-section {
        background: white;
        padding: 5rem 1.5rem;
    }

    .roles-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.75rem;
        max-width: 1100px;
        margin: 0 auto;
    }

    .role-card {
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        transition: transform 0.3s;
    }

        .role-card:hover {
            transform: translateY(-5px);
        }

    .role-img {
        width: 100%;
        height: 200px;
        object-fit: cover;
        display: block;
    }

    .role-body {
        padding: 1.75rem;
        color: white;
    }

    .role-card.admin .role-body {
        background: linear-gradient(135deg, #0f1f3d, #1a3a6b);
    }

    .role-card.owner .role-body {
        background: linear-gradient(135deg, #7b4f00, #c87f0a);
    }

    .role-card.tenant .role-body {
        background: linear-gradient(135deg, #145a32, #1e8449);
    }

    .role-icon {
        font-size: 2rem;
        margin-bottom: 0.75rem;
        display: block;
    }

    .role-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 0.6rem;
    }

    .role-desc {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.86rem;
        opacity: 0.85;
        line-height: 1.7;
        margin-bottom: 1.25rem;
    }

    .role-perms {
        list-style: none;
    }

        .role-perms li {
            font-family: 'DM Sans', sans-serif;
            font-size: 0.82rem;
            opacity: 0.9;
            padding: 0.28rem 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

            .role-perms li::before {
                content: '✓';
                font-weight: 700;
            }

    /* CTA */
    .cta-section {
        position: relative;
        padding: 6rem 1.5rem;
        text-align: center;
        color: white;
        overflow: hidden;
    }

    .cta-bg {
        position: absolute;
        inset: 0;
        background-image: url('https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=1600&q=80');
        background-size: cover;
        background-position: center;
        filter: brightness(0.3);
        z-index: 0;
    }

    .cta-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(10,10,30,0.8), rgba(10,48,96,0.75));
        z-index: 1;
    }

    .cta-content {
        position: relative;
        z-index: 2;
    }

    .cta-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.8rem;
        font-weight: 900;
        margin-bottom: 1rem;
    }

    .cta-desc {
        font-family: 'DM Sans', sans-serif;
        font-size: 1.05rem;
        color: rgba(255,255,255,0.7);
        margin-bottom: 2.5rem;
        max-width: 500px;
        margin-left: auto;
        margin-right: auto;
    }

    @@media (max-width: 768px) {
        .hero-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .hero-title {
            font-size: 2.4rem;
        }

        .hero-visual {
            display: none;
        }

        .stats-inner {
            grid-template-columns: repeat(2, 1fr);
        }

        .features-grid, .roles-grid {
            grid-template-columns: 1fr;
        }

        .stat-item {
            border-right: none;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }
    }
</style>

<!-- HERO -->
<section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-grid">
        <div class="hero-text">
            <div class="hero-eyebrow">Property Management System</div>
            <h1 class="hero-title">
                Manage Every
                <span>Property With</span>
                Confidence.
            </h1>
            <p class="hero-desc">
                A complete platform for property owners, tenants, and administrators.
                Track leases, manage listings, and streamline your real estate portfolio
                all in one place.
            </p>
            <div class="hero-buttons">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Properties" asp-action="Index" class="btn-hero-primary">🏠 View Properties</a>
                    <a asp-controller="LeaseAgreements" asp-action="Index" class="btn-hero-secondary">📄 View Leases</a>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn-hero-primary">🔐 Login to Get Started</a>
                }
            </div>
        </div>

        <div class="hero-visual">
            <div class="prop-card-img">
                <img src="https://images.unsplash.com/photo-1568605114967-8130f3a36994?w=800&q=80" alt="Modern Home" />
                <div class="prop-card-overlay">
                    <div class="prop-tag">Featured Listing</div>
                    <div class="prop-name">123 Oakwood Drive, Mobile AL <span class="prop-badge">ACTIVE</span></div>
                    <div class="prop-price-tag">$485,000</div>
                </div>
            </div>
            <div class="prop-card-row">
                <div class="prop-card-img small">
                    <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=600&q=80" alt="House" />
                    <div class="prop-card-overlay">
                        <div class="prop-tag">Residential</div>
                        <div class="prop-price-tag">$320,000</div>
                    </div>
                </div>
                <div class="prop-card-img small">
                    <img src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=600&q=80" alt="Luxury Home" />
                    <div class="prop-card-overlay">
                        <div class="prop-tag">Luxury</div>
                        <div class="prop-price-tag">$1.2M</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- STATS -->
<section class="stats-bar">
    <div class="stats-inner">
        <div class="stat-item">
            <span class="stat-number">3</span>
            <div class="stat-label">User Roles</div>
        </div>
        <div class="stat-item">
            <span class="stat-number">100%</span>
            <div class="stat-label">Secure Access</div>
        </div>
        <div class="stat-item">
            <span class="stat-number">5</span>
            <div class="stat-label">Core Modules</div>
        </div>
        <div class="stat-item">
            <span class="stat-number">24/7</span>
            <div class="stat-label">Availability</div>
        </div>
    </div>
</section>

<!-- FEATURES with images -->
<section class="features-section">
    <div class="section-label">What We Offer</div>
    <h2 class="section-title">Everything You Need</h2>
    <div class="features-grid">
        <div class="feature-card">
            <img class="feature-img" src="https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=600&q=80" alt="Property" />
            <div class="feature-body">
                <span class="feature-emoji">🏠</span>
                <div class="feature-title">Property Management</div>
                <p class="feature-desc">Add, edit, and track all your property listings with full address details and pricing information.</p>
            </div>
        </div>
        <div class="feature-card">
            <img class="feature-img" src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=600&q=80" alt="Lease" />
            <div class="feature-body">
                <span class="feature-emoji">📄</span>
                <div class="feature-title">Lease Agreements</div>
                <p class="feature-desc">Create and manage lease agreements with start dates, end dates, and monthly rent tracking.</p>
            </div>
        </div>
        <div class="feature-card">
            <img class="feature-img" src="https://images.unsplash.com/photo-1521791136064-7986c2920216?w=600&q=80" alt="Tenants" />
            <div class="feature-body">
                <span class="feature-emoji">👥</span>
                <div class="feature-title">Tenant Management</div>
                <p class="feature-desc">Keep track of tenant information, employment details, and income verification in one place.</p>
            </div>
        </div>
        <div class="feature-card">
            <img class="feature-img" src="https://images.unsplash.com/photo-1494526585095-c41746248156?w=600&q=80" alt="Owner" />
            <div class="feature-body">
                <span class="feature-emoji">🔑</span>
                <div class="feature-title">Owner Portal</div>
                <p class="feature-desc">Owners can view and manage their own properties and associated lease agreements securely.</p>
            </div>
        </div>
        <div class="feature-card">
            <img class="feature-img" src="https://images.unsplash.com/photo-1563986768609-322da13575f3?w=600&q=80" alt="Security" />
            <div class="feature-body">
                <span class="feature-emoji">🔒</span>
                <div class="feature-title">Role-Based Security</div>
                <p class="feature-desc">Admin, Owner, and Tenant roles ensure every user only sees what they are authorized to access.</p>
            </div>
        </div>
        <div class="feature-card">
            <img class="feature-img" src="https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=600&q=80" alt="Ownership" />
            <div class="feature-body">
                <span class="feature-emoji">🔗</span>
                <div class="feature-title">Property Ownership</div>
                <p class="feature-desc">Link multiple owners to properties through a flexible ownership assignment system.</p>
            </div>
        </div>
    </div>
</section>

<!-- ROLES with images -->
<section class="roles-section">
    <div class="section-label">Access Levels</div>
    <h2 class="section-title">Built for Every User</h2>
    <div class="roles-grid">
        <div class="role-card admin">
            <img class="role-img" src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&q=80" alt="Admin" />
            <div class="role-body">
                <span class="role-icon">🛡️</span>
                <div class="role-title">Administrator</div>
                <p class="role-desc">Full control over the entire system. Manages all users, properties, and data.</p>
                <ul class="role-perms">
                    <li>Full CRUD on all records</li>
                    <li>Create Owner & Tenant accounts</li>
                    <li>Assign properties to owners</li>
                    <li>Delete leases and properties</li>
                </ul>
            </div>
        </div>
        <div class="role-card owner">
            <img class="role-img" src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=600&q=80" alt="Owner" />
            <div class="role-body">
                <span class="role-icon">🏠</span>
                <div class="role-title">Property Owner</div>
                <p class="role-desc">Manage your own properties and associated lease agreements.</p>
                <ul class="role-perms">
                    <li>View & edit own properties</li>
                    <li>Create & edit lease agreements</li>
                    <li>View tenant information</li>
                    <li>Track rental income</li>
                </ul>
            </div>
        </div>
        <div class="role-card tenant">
            <img class="role-img" src="https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=600&q=80" alt="Tenant" />
            <div class="role-body">
                <span class="role-icon">🪪</span>
                <div class="role-title">Tenant</div>
                <p class="role-desc">View your lease details and property information assigned to you.</p>
                <ul class="role-perms">
                    <li>View lease agreement details</li>
                    <li>View property information</li>
                    <li>Access personal profile</li>
                    <li>Secure read-only access</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- CTA with background image -->
@if (User.Identity == null || !User.Identity.IsAuthenticated)
{
    <section class="cta-section">
        <div class="cta-bg"></div>
        <div class="cta-overlay"></div>
        <div class="cta-content">
            <h2 class="cta-title">Ready to Get Started?</h2>
            <p class="cta-desc">Log in to access your property management dashboard and take control of your portfolio.</p>
            <a asp-area="Identity" asp-page="/Account/Login" class="btn-hero-primary" style="font-size:1.05rem; padding: 1rem 2.5rem;">
                🔐 Login Now
            </a>
        </div>
    </section>
}