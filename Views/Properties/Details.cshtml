@model Cherukuri_Spring26.Models.Property
@{
    ViewData["Title"] = "Property Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Property Details</h1>

<div>
    <h4>Property</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Address)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Address)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.City)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.City)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.State)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.State)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ZipCode)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ZipCode)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ListingPrice)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ListingPrice)
        </dd>

        <dt class="col-sm-2">
            Full Address
        </dt>
        <dd class="col-sm-10">
            @Model.Address, @Model.City, @Model.State @Model.ZipCode
        </dd>
    </dl>
</div>

<div>
    @if (User.IsInRole("Admin") || User.IsInRole("Owner"))
    {
        <a asp-action="Edit" asp-route-id="@Model?.PropertyID" class="btn btn-warning">Edit</a>
    }
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>