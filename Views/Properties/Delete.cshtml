@model Cherukuri_Spring26.Models.Property
@{
    ViewData["Title"] = "Delete Property";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Delete Property</h1>
<h3 class="text-danger">Are you sure you want to delete this?</h3>

<div>
    <h4>Property</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Address)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Address)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.City)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.City)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.State)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.State)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ZipCode)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ZipCode)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ListingPrice)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ListingPrice)
        </dd>

        <dt class="col-sm-2">
            Full Address
        </dt>
        <dd class="col-sm-10">
            @Model.Address, @Model.City, @Model.State @Model.ZipCode
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="PropertyID" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>